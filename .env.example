# JASWOLF_API_KEYS — comma-separated keys for REST API auth (REQUIRED for production)
# Generate one: python3 -c "import secrets; print('jsk-' + secrets.token_hex(32))"
# JASWOLF_API_KEYS=jsk-your-key-here

# Database URL (default: local SQLite)
# JASWOLF_DATABASE_URL=sqlite:///./jaswolf.db

# Embedding provider (default: local with BAAI/bge-small-en-v1.5)
# JASWOLF_EMBEDDING_PROVIDER=local
# JASWOLF_EMBEDDING_MODEL=BAAI/bge-small-en-v1.5

# For OpenAI-compatible embeddings:
# JASWOLF_EMBEDDING_PROVIDER=openai
# JASWOLF_OPENAI_BASE_URL=https://api.openai.com/v1
# JASWOLF_OPENAI_API_KEY=sk-...
